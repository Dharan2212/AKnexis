{
  "compilerOptions": {
    "lib": ["es2020"],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./.ts-build",
    "paths": {
      "@/*": ["./*"]
    },
    "baseUrl": "."
  },
  "include": ["scripts/**/*.ts", "lib/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules"]
}
