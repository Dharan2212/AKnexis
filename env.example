# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENV=development

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true
MONGODB_DB_NAME=aknexis

# Auth
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-64-characters-long-please-change-this
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12
COOKIE_NAME=aknexis_session

# Security
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Storage
STORAGE_PROVIDER=s3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=aknexis-files
S3_UPLOAD_MAX_SIZE_MB=50

# Email
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=aknexis.in@gmail.com
EMAIL_NOTIFY_LEADS=aknexis.in@gmail.com
SENDGRID_API_KEY=your-sendgrid-api-key

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
